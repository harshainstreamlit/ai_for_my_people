# Convex
# After running `npx convex dev` or creating a Convex deployment, paste the public URL here.
VITE_CONVEX_URL=
VITE_ENABLE_ANALYTICS=true

# Optional: Netlify site URL for share text and OG links after deployment.
VITE_PUBLIC_SITE_URL=

# Harsha WhatsApp number, country code only, no plus sign.
VITE_HARSHA_WHATSAPP_NUMBER=918374283166

# Supabase browser client. Use the public anon/publishable key here, not the service-role secret.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Supabase server/admin key for future Netlify functions only. Never expose this with VITE_.
SUPABASE_SERVICE_ROLE_KEY=

# Netlify/Convex deployment helpers. These are not exposed to the browser.
CONVEX_DEPLOY_KEY=
CONVEX_DEPLOYMENT=
